{
  "pluginName": "udict",
  "description": "Offline MDX/MDD dictionary lookup",
  "author": "udict",
  "version": "0.3.0",
  "logo": "logo.png",
  "main": "index.html",
  "preload": "preload.js",
  "features": [
    {
      "code": "udict",
      "explain": "Look up a word in local MDX dictionaries",
      "cmds": [
        "udict",
        { "type": "over", "label": "udict 查词" },
        { "type": "regex", "label": "udict 查词", "match": "/^[\\u4e00-\\u9fa5a-zA-Z]{1,50}$/" }
      ]
    }
  ]
}
